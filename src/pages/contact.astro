---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | retaliatoryfirecalc.com';
const description = 'Contact the editorial team at retaliatoryfirecalc.com for corrections, feedback, or questions about the site.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>For corrections, feedback, or questions about the site, email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
  <p>We read every message and respond to factual correction reports promptly. We cannot provide legal advice or respond to requests for case-specific analysis — if you need legal guidance about a retaliation situation, please consult a licensed employment attorney. Most employment attorneys offer free initial consultations and accept retaliation cases on contingency.</p>
  <p>For OSHA retaliation specifically: if the 30-day deadline is approaching, please contact OSHA directly at 1-800-321-OSHA or file online at <a href="https://www.osha.gov" target="_blank" rel="noopener">osha.gov</a> — do not wait for us to respond first.</p>
</BaseLayout>
