---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | retaliatoryfirecalc.com';
const description = 'Privacy policy for retaliatoryfirecalc.com — what data we collect, how it is used, and your choices regarding cookies and advertising.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026</p>

  <h2>Information We Collect</h2>
  <p>retaliatoryfirecalc.com does not collect personal information directly from visitors. We do not require account registration, do not store calculator inputs, and do not transmit the information you enter into our calculator to any server — all calculations run locally in your browser.</p>
  <p>We use Google AdSense to serve advertising and Google Analytics to understand aggregate traffic patterns. Both services collect usage data as described in Google&rsquo;s privacy policy. Google AdSense may use cookies and device identifiers to serve ads relevant to your interests based on your browsing activity across sites that participate in Google&rsquo;s advertising network.</p>

  <h2>Cookies</h2>
  <p>Our site uses cookies placed by Google AdSense for advertising purposes and Google Analytics for aggregate traffic measurement. We do not place first-party cookies for tracking or advertising. You can opt out of personalized Google advertising by visiting <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>. You can also manage cookie preferences in your browser settings.</p>

  <h2>Third-Party Services</h2>
  <p>The third-party services operating on this site are:</p>
  <ul>
    <li><strong>Google AdSense</strong> — display advertising. Subject to <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google&rsquo;s Privacy Policy</a>.</li>
    <li><strong>Google Analytics</strong> — aggregate traffic analysis (page views, session counts, general geographic distribution). We do not use Google Analytics to identify individual visitors. Subject to Google&rsquo;s Privacy Policy.</li>
  </ul>

  <h2>Data Retention</h2>
  <p>We do not store visitor data on our own servers. Google Analytics data is retained per Google&rsquo;s standard retention settings. You can request deletion of your Google Analytics data by using Google&rsquo;s opt-out tools.</p>

  <h2>Children&rsquo;s Privacy</h2>
  <p>This site is not directed to children under 13 and we do not knowingly collect information from children.</p>

  <h2>Changes to This Policy</h2>
  <p>We may update this privacy policy to reflect changes in our practices or applicable law. The effective date at the top of this page will be updated when changes are made.</p>

  <h2>Contact</h2>
  <p>Questions about this privacy policy? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
